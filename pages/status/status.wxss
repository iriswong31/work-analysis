/* 审核状态页样式 */
.page {
  min-height: 100vh;
  background: #f8f4f4;
}

/* 状态容器 */
.status-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

/* 状态图标 */
.status-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.status-icon.pending {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
}

.status-icon.approved {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
}

.status-icon.rejected {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
}

.status-icon .icon {
  font-size: 72rpx;
}

.status-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF9800;
  margin-bottom: 12rpx;
}

.success-text {
  color: #4CAF50;
}

.rejected-text {
  color: #E74C3C;
}

.status-desc {
  font-size: 28rpx;
  color: #777;
  margin-bottom: 8rpx;
}

.status-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 时间线 */
.status-timeline {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding-bottom: 32rpx;
  position: relative;
  padding-left: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 24rpx;
  bottom: 0;
  width: 4rpx;
  background: #e0e0e0;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e0e0e0;
  border: 4rpx solid #f0f0f0;
  z-index: 1;
}

.timeline-item.done .timeline-dot {
  background: #4CAF50;
  border-color: #E8F5E9;
}

.timeline-item.active .timeline-dot {
  background: #FF9800;
  border-color: #FFF3E0;
  box-shadow: 0 0 0 8rpx rgba(255, 152, 0, 0.15);
}

.timeline-item.done::before {
  background: #4CAF50;
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.timeline-item.done .timeline-title {
  color: #4CAF50;
}

.timeline-item.active .timeline-title {
  color: #FF9800;
  font-weight: bold;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.timeline-item.active .timeline-time {
  color: #FF9800;
}

/* 驳回原因 */
.reject-reason {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.reason-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.reason-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.reason-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.reason-content {
  font-size: 28rpx;
  color: #E74C3C;
  line-height: 1.6;
  padding: 16rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
}

/* 操作按钮 */
.success-actions, .reject-actions {
  width: 100%;
  margin-top: 40rpx;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #bbb;
}
