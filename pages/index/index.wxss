/* 首页样式 */
.page {
  min-height: 100vh;
  background: #f8f4f4;
  padding-bottom: 160rpx;
}

/* Banner */
.banner {
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.banner-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FF8A80, #FF5252, #E74C3C, #FF6B6B);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.banner-bg::before {
  content: '';
  position: absolute;
  top: -40rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.banner-bg::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  right: -30rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.banner-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 2rpx 4rpx 8rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 8rpx;
  z-index: 1;
}

.banner-deco {
  display: flex;
  gap: 40rpx;
  margin-top: 16rpx;
  z-index: 1;
}

.deco-heart, .deco-flower, .deco-house {
  font-size: 40rpx;
  animation: float 3s ease-in-out infinite;
}

.deco-flower {
  animation-delay: 0.5s;
}

.deco-house {
  animation-delay: 1s;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 关闭按钮 */
.close-btn {
  position: absolute;
  top: 340rpx;
  right: 40rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.close-btn text {
  font-size: 36rpx;
  color: #999;
}

/* 介绍卡片 */
.intro-card {
  margin-top: -40rpx;
  border-radius: 24rpx 24rpx 20rpx 20rpx;
  position: relative;
  z-index: 2;
  background: #fff;
  padding: 40rpx 32rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.card-icon {
  margin-bottom: 24rpx;
}

.house-icon {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.icon-text {
  font-size: 80rpx;
}

.icon-flower {
  font-size: 36rpx;
  position: absolute;
  top: -8rpx;
  right: -20rpx;
}

.intro-content {
  line-height: 1.8;
  font-size: 28rpx;
  color: #555;
}

.highlight-tag {
  background: linear-gradient(180deg, transparent 60%, rgba(231, 76, 60, 0.15) 60%);
  color: #E74C3C;
  font-weight: bold;
  padding: 0 4rpx;
}

.intro-text {
  color: #555;
}

/* 步骤卡片 */
.steps-card {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.steps-list {
  margin-top: 8rpx;
}

.step-item {
  background: linear-gradient(135deg, #FFF9F8, #FFF5F3);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #FFD4CC;
}

.step-item-last {
  margin-bottom: 0;
}

.step-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF6B6B, #E74C3C);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-number .num {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
}

.step-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.step-desc {
  padding-left: 64rpx;
  font-size: 26rpx;
  color: #777;
  line-height: 1.6;
}

/* 底部 */
.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B, #E74C3C);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 4rpx;
}

.login-btn::after {
  border: none;
}
