<!-- 爱心商户登录页 -->
<view class="page">
  <!-- 顶部装饰 -->
  <view class="header">
    <view class="header-bg">
      <view class="header-icon">❤️</view>
      <text class="header-title">爱心商户登录</text>
      <text class="header-subtitle">欢迎加入关爱平台</text>
    </view>
  </view>

  <!-- 登录表单 -->
  <view class="form-card">
    <!-- 邀请码登录（默认方式） -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'invite' ? 'active' : ''}}" bindtap="switchTab" data-tab="invite">
        <text>邀请码登录</text>
      </view>
      <view class="tab-item {{activeTab === 'phone' ? 'active' : ''}}" bindtap="switchTab" data-tab="phone">
        <text>手机号登录</text>
      </view>
    </view>

    <!-- 邀请码表单 -->
    <view class="form-body" wx:if="{{activeTab === 'invite'}}">
      <view class="form-group">
        <view class="form-label">邀请码</view>
        <input
          class="form-input"
          type="text"
          placeholder="请输入公益机构提供的邀请码"
          value="{{inviteCode}}"
          bindinput="onInviteCodeInput"
          maxlength="20"
        />
      </view>

      <view class="form-group">
        <view class="form-label">手机号</view>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>

      <view class="form-group">
        <view class="form-label">验证码</view>
        <view class="code-input-wrapper">
          <input
            class="form-input code-input"
            type="number"
            placeholder="请输入验证码"
            value="{{smsCode}}"
            bindinput="onSmsCodeInput"
            maxlength="6"
          />
          <view class="code-btn {{codeBtnDisabled ? 'disabled' : ''}}" bindtap="sendSmsCode">
            <text>{{codeText}}</text>
          </view>
        </view>
      </view>

      <view class="form-tip">
        <text class="tip-icon">💡</text>
        <text>邀请码由合作公益机构提供，请联系对应机构获取</text>
      </view>
    </view>

    <!-- 手机号表单 -->
    <view class="form-body" wx:if="{{activeTab === 'phone'}}">
      <view class="form-group">
        <view class="form-label">手机号</view>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>

      <view class="form-group">
        <view class="form-label">验证码</view>
        <view class="code-input-wrapper">
          <input
            class="form-input code-input"
            type="number"
            placeholder="请输入验证码"
            value="{{smsCode}}"
            bindinput="onSmsCodeInput"
            maxlength="6"
          />
          <view class="code-btn {{codeBtnDisabled ? 'disabled' : ''}}" bindtap="sendSmsCode">
            <text>{{codeText}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 协议 -->
    <view class="agreement">
      <view class="checkbox-wrapper" bindtap="toggleAgreement">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}">✓</text>
        </view>
      </view>
      <text class="agreement-text">
        我已阅读并同意
        <text class="link" bindtap="showAgreement" data-type="service">《服务协议》</text>
        和
        <text class="link" bindtap="showAgreement" data-type="privacy">《隐私政策》</text>
      </text>
    </view>

    <!-- 登录按钮 -->
    <button class="btn-primary" bindtap="handleLogin" loading="{{loading}}">
      {{activeTab === 'invite' ? '验证并登录' : '登录'}}
    </button>
  </view>
</view>
