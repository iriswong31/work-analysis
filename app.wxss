/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B, #E74C3C);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 4rpx;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #E74C3C;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E74C3C;
}

.btn-outline::after {
  border: none;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title .bar {
  width: 8rpx;
  height: 40rpx;
  background: #E74C3C;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title .text {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
}
